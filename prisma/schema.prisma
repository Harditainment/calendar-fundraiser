generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  passwordHash       String
  stripeCustomerId   String?
  createdAt          DateTime @default(now())
  claims             DateClaim[]
}

// Each specific calendar date (e.g. March 1, 2026) can be claimed by at
// most ONE user system-wide. The @unique on `date` enforces global
// uniqueness across all users. Amount is always equal to the day-of-month
// in dollars (e.g. the 1st = $1, the 31st = $31), charged immediately.
model DateClaim {
  id                String   @id @default(uuid())
  date              DateTime @unique @db.Date
  amountCents       Int
  status            ClaimStatus @default(CHARGED)
  failureReason     String?
  chargedAt         DateTime @default(now())
  createdAt         DateTime @default(now())

  userId            String
  user              User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

enum ClaimStatus {
  CHARGED  // payment succeeded, date is locked
  FAILED   // payment failed; date stays open (kept briefly for the user's own history)
}
