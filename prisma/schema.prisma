generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  passwordHash       String
  stripeCustomerId   String?
  createdAt          DateTime @default(now())
  claims             DateClaim[]
}

// Each user has their own personal calendar of (month, day) cells.
// A cell is uniquely identified per user by month (1-12) and day (1-31).
// Once charged, it's permanently locked for that user. Amount = day number
// in dollars (e.g. day 15 = $15).
model DateClaim {
  id                String   @id @default(uuid())
  month             Int      // 1-12
  day               Int      // 1-31
  amountCents       Int
  status            ClaimStatus @default(CHARGED)
  failureReason     String?
  chargedAt         DateTime @default(now())
  createdAt         DateTime @default(now())

  userId            String
  user              User     @relation(fields: [userId], references: [id])

  @@unique([userId, month, day])
  @@index([userId])
}

enum ClaimStatus {
  CHARGED  // payment succeeded, cell is locked
  FAILED   // payment failed; cell stays open (kept briefly for the user's own history)
}
